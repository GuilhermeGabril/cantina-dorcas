{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/vendas/(.*)",
      "dest": "backend/server.ts"
    },
    {
      "src": "/produtos/(.*)",
      "dest": "backend/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.ts"
    }
  ]
}